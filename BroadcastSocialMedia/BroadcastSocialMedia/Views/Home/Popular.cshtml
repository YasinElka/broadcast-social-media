@model BroadcastSocialMedia.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Populära inlägg";
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="fas fa-fire text-warning"></i> @ViewData["Title"]</h1>

    @if (!Model.Broadcasts.Any())
    {
        <div class="alert alert-info">
            Inga populära inlägg ännu.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var broadcast in Model.Broadcasts)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <div class="d-flex align-items-center">
                                <!-- PROFILBILD - Detta saknas i din vy! -->
                                <img src="@broadcast.UserProfileImage"
                                     alt="@broadcast.UserName"
                                     class="rounded-circle me-2 border"
                                     style="width: 40px; height: 40px; object-fit: cover;"
                                     onerror="this.src='/images/default-avatar.png'" />

                                <div>
                                    <strong>@broadcast.UserName</strong>
                                    <small class="text-muted d-block">@broadcast.CreatedAt.ToString("g")</small>
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <p class="card-text">@broadcast.Content</p>

                            @if (!string.IsNullOrEmpty(broadcast.ImageUrl))
                            {
                                <img src="@broadcast.ImageUrl"
                                     class="img-fluid rounded mb-3"
                                     style="max-height: 300px; width: 100%; object-fit: cover;" />
                            }

                            <div class="d-flex justify-content-between align-items-center">
                                <form asp-action="Like" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="broadcastId" value="@broadcast.Id" />
                                    <button type="submit"
                                            class="btn btn-sm @(broadcast.IsLikedByCurrentUser ? "btn-danger" : "btn-outline-danger")">
                                        <i class="fas fa-heart"></i> @broadcast.LikeCount
                                    </button>
                                </form>

                                <a asp-action="Profile" asp-route-id="@broadcast.UserId"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-user"></i> Profil
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Tillbaka
        </a>
    </div>
</div>