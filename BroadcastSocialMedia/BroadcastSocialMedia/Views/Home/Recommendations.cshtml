@model IEnumerable<BroadcastSocialMedia.ViewModels.UserRecommendationViewModel>

@{
    ViewData["Title"] = "Rekommenderade användare";
}

<h1>Rekommenderade användare</h1>
<p class="text-muted">Här är några användare du kanske vill följa</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Inga rekommendationer just nu. Kom tillbaka senare!
    </div>
}
else
{
    <div class="row">
        @foreach (var user in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <img src="@user.ProfileImageUrl"
                             alt="@user.UserName"
                             class="rounded-circle mb-3"
                             style="width: 80px; height: 80px; object-fit: cover;" />

                        <h5 class="card-title">@user.UserName</h5>

                        @if (!string.IsNullOrEmpty(user.Bio))
                        {
                            <p class="card-text text-muted small">@user.Bio</p>
                        }

                        <p class="text-muted">
                            <i class="fas fa-users"></i> @user.FollowerCount följare
                        </p>

                        <form asp-action="Follow" asp-controller="Home" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.UserId" />
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-user-plus"></i> Följ
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Tillbaka
    </a>
</div>