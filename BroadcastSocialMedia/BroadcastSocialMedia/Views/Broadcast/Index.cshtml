@model BroadcastSocialMedia.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Broadcasts";
}

<div class="container">
    <h1>Broadcasts</h1>

    @if (!Model.Broadcasts.Any())
    {
        <div class="alert alert-info">
            No broadcasts to show.
        </div>
    }

    @foreach (var broadcast in Model.Broadcasts)
    {
        <div class="broadcast-card">
            <div class="broadcast-header">
                <img src="@broadcast.UserProfileImage"
                     alt="@broadcast.UserName"
                     class="user-avatar"
                     onerror="this.src='/images/default-avatar.png'" />
                <div>
                    <h5>@broadcast.UserName</h5>
                    <small>@broadcast.CreatedAt.ToString("g")</small>
                </div>

                <!-- UNFOLLOW-FORMULÄR-->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="ms-auto">
                        <form asp-action="Unfollow" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@broadcast.Id">
                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm"
                                    title="Unfollow @broadcast.UserName"
                                    onclick="return confirm('Unfollow @broadcast.UserName?')">
                                <i class="fas fa-user-minus"></i> Unfollow
                            </button>
                        </form>
                    </div>
                }
            </div> 

            <p>@broadcast.Content</p>

            @if (!string.IsNullOrEmpty(broadcast.ImageUrl))
            {
                <img src="@broadcast.ImageUrl"
                     alt="Broadcast image"
                     class="broadcast-image" />
            }

           

            <!-- Like-knapp -->
            <form asp-controller="Broadcast" asp-action="Like" method="post">
                <input type="hidden" name="id" value="@broadcast.Id" />
                <button type="submit" class="btn @(broadcast.IsLikedByCurrentUser ? "btn-danger" : "btn-outline-danger")">
                    @if (broadcast.IsLikedByCurrentUser)
                    {
                        <span>❤️ Liked</span>
                    }
                    else
                    {
                        <span>🤍 Like</span>
                    }
                    <span class="badge bg-secondary">@broadcast.LikeCount</span>
                </button>
            </form>
        </div>
    }
</div>

<style>
    .broadcast-card {
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 20px;
        background: white;
    }

    .broadcast-header {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

    .user-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 15px;
    }

    .broadcast-image {
        max-width: 100%;
        border-radius: 8px;
        margin: 10px 0;
    }

    .platform-badge {
        display: inline-block;
        background: #007bff;
        color: white;
        padding: 3px 10px;
        border-radius: 15px;
        font-size: 12px;
        margin: 5px 0;
    }
</style>